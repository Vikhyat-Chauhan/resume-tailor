# LLM provider — prefix the model name to select provider (LiteLLM routing)
# OpenAI:    LLM_MODEL=gpt-4o             LLM_API_KEY=sk-...
# Anthropic: LLM_MODEL=anthropic/claude-sonnet-4-5   LLM_API_KEY=sk-ant-...
# Ollama:    LLM_MODEL=ollama/llama3.1    (no key needed, runs locally)

LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o

OUTPUT_FORMAT=pdf
OUTPUT_DIR=outputs
LATEX_CMD=pdflatex
